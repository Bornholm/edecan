package page

import (
	"edecan/internal/http/view/component"
	"edecan/internal/http/view/layout"
)

// PublicConversationProps configure la vue publique en lecture seule d'une
// conversation partagée (PLAN-UX-CHAT §Phase 4.5).
type PublicConversationProps struct {
	// Title est le titre de la session, affiché en tête — c'est la seule
	// métadonnée exposée ; aucune donnée identifiante (email, nom réel,
	// horodatage) n'accompagne les messages.
	Title    string
	Messages []component.ChatMessageProps
}

// PublicConversation rend l'instantané figé d'une conversation via le même
// composant que le chat privé (rendu Markdown identique), mais dans la coquille
// publique dépouillée. Les auteurs sont anonymisés en amont (« Utilisateur » /
// « Agent »), aucun horodatage ni raisonnement interne n'est transmis.
templ PublicConversation(props PublicConversationProps) {
	@layout.PublicShell("Conversation partagée · lecture seule") {
		<div class="edc-public__conversation">
			if props.Title != "" {
				<h1 class="edc-public__title">{ props.Title }</h1>
			}
			<div class="edc-public__note">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M12 2a10 10 0 100 20 10 10 0 000-20z"></path>
					<path d="M12 16v-4M12 8h.01"></path>
				</svg>
				<span>Instantané de la conversation, en lecture seule. Les échanges ultérieurs ne sont pas visibles.</span>
			</div>
			<div class="edc-chat__messages-inner edc-public__messages">
				if len(props.Messages) == 0 {
					<div class="edc-public__empty">Cette conversation ne contient encore aucun message.</div>
				} else {
					for _, m := range props.Messages {
						@component.ChatMessage(m)
					}
				}
			</div>
		</div>
	}
}
