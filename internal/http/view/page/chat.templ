package page

import (
	"edecan/internal/http/view/component"
	"edecan/internal/http/view/layout"
)

// SessionEntry est une entrée de la liste des sessions du projet
// (SPEC §Chat, points 8-9 : sessions parallèles, reprise).
type SessionEntry struct {
	ID        string
	Title     string
	Active    bool
	TicketRef string // non vide ⇒ "A donné lieu au ticket #N" (SPEC §Handover, point 19)
}

// ChatProps configure la page Chat.
type ChatProps struct {
	ProjectSlug       string
	ProjectName       string
	UserDisplayName   string
	UserRoleLabel     string
	Projects          []layout.ProjectOption
	Sessions          []SessionEntry
	CurrentSession    *SessionEntry
	Messages          []component.ChatMessageProps
	AlreadyFlagged    bool
	ActiveTicketCount int
}

func sessionHref(slug, id string) string { return "/projects/" + slug + "/chat/" + id }

// chatSidebar liste les sessions du projet dans le rail latéral, avec
// l'action de démarrage d'une nouvelle session (cf. maquette : panneau
// "Sessions" avec bouton "+").
templ chatSidebar(props ChatProps) {
	<div class="edc-rail__list-heading">
		<span>Sessions</span>
		<form method="post" action={ templ.SafeURL("/projects/" + props.ProjectSlug + "/chat/sessions") }>
			<button type="submit" class="edc-rail__list-add" aria-label="Nouvelle session">
				<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
					<path d="M12 5v14M5 12h14"></path>
				</svg>
			</button>
		</form>
	</div>
	if len(props.Sessions) == 0 {
		<div class="edc-rail__list-empty">Aucune session.</div>
	} else {
		for _, s := range props.Sessions {
			<div class={ "edc-session-item", templ.KV("edc-session-item--active", s.Active) }>
				<a class="edc-session-item__link" href={ templ.SafeURL(sessionHref(props.ProjectSlug, s.ID)) }>
					<div class="edc-session-item__row">
						<span class="edc-session-item__title">
							if s.Title != "" {
								{ s.Title }
							} else {
								Session #{ s.ID }
							}
						</span>
					</div>
					if s.TicketRef != "" {
						<div class="edc-session-item__meta">
							<span class="edc-session-item__chip edc-session-item__chip--ticket">#{ s.TicketRef }</span>
						</div>
					}
				</a>
				if s.TicketRef == "" {
					<form
						method="post"
						action={ templ.SafeURL(sessionHref(props.ProjectSlug, s.ID) + "/delete") }
						onsubmit="return confirm('Supprimer cette session ? Cette action est irréversible.')"
					>
						<button type="submit" class="edc-session-item__delete" aria-label="Supprimer la session">
							<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M3 6h18M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2m3 0l-1 14a2 2 0 01-2 2H7a2 2 0 01-2-2L4 6"></path>
							</svg>
						</button>
					</form>
				}
			</div>
		}
	}
}

// Chat est la vue Session : rail latéral avec la liste des sessions,
// conversation et actions contextuelles (handover, FAQ) dans l'en-tête
// (SPEC §UI/UX Considerations ; cf. maquette).
templ Chat(props ChatProps) {
	@layout.Shell(layout.ShellProps{
		Title:             "Chat",
		UserDisplayName:   props.UserDisplayName,
		UserRoleLabel:     props.UserRoleLabel,
		ProjectName:       props.ProjectName,
		ProjectSlug:       props.ProjectSlug,
		Projects:          props.Projects,
		ActiveNav:         "chat",
		ActiveTicketCount: props.ActiveTicketCount,
		Sidebar:           chatSidebar(props),
	}) {
		if props.CurrentSession == nil {
			<div class="edc-empty">
				<div class="edc-empty__icon">
					<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
						<path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"></path>
					</svg>
				</div>
				<div class="edc-empty__title">Aucune session sélectionnée</div>
				<div class="edc-empty__subtitle">Choisissez une session dans la liste ou démarrez-en une nouvelle</div>
				<form method="post" action={ templ.SafeURL("/projects/" + props.ProjectSlug + "/chat/sessions") }>
					<button type="submit" class="edc-btn edc-btn--primary-subtle edc-btn--sm" style="margin-top:4px;">
						<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 5v14M5 12h14"></path>
						</svg>
						Nouvelle session
					</button>
				</form>
			</div>
		} else {
			<div class="edc-chat">
				<div class="edc-chat-header">
					<div style="min-width:0;">
						<div class="edc-chat-header__title">
							if props.CurrentSession.Title != "" {
								{ props.CurrentSession.Title }
							} else {
								Session #{ props.CurrentSession.ID }
							}
						</div>
						<div class="edc-chat-header__sub">
							<span class="edc-chat-header__status-dot"></span>
							<span>Agent actif</span>
							if props.CurrentSession.TicketRef != "" {
								<a class="edc-chat-header__ticket-link" href={ templ.SafeURL("/projects/" + props.ProjectSlug + "/tickets/" + props.CurrentSession.TicketRef) }>
									Ticket #{ props.CurrentSession.TicketRef }
								</a>
							}
						</div>
					</div>
					<div class="edc-chat-header__actions">
						if props.AlreadyFlagged {
							@component.Badge(component.BadgeProps{Variant: component.BadgeSuccess}) {
								Merci pour votre retour
							}
						} else {
							<button
								class="edc-btn edc-btn--secondary edc-btn--sm"
								type="button"
								hx-post={ string(templ.SafeURL(sessionHref(props.ProjectSlug, props.CurrentSession.ID) + "/relevance")) }
								hx-swap="outerHTML"
							>
								<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3H14z"></path>
									<path d="M7 22H4a2 2 0 01-2-2v-7a2 2 0 012-2h3"></path>
								</svg>
								Utile
							</button>
						}
						if props.CurrentSession.TicketRef == "" {
							<button
								class="edc-btn edc-btn--primary-subtle edc-btn--sm"
								type="button"
								hx-get={ string(templ.SafeURL(sessionHref(props.ProjectSlug, props.CurrentSession.ID) + "/handover/modal")) }
								hx-target="#modal-root"
								hx-swap="innerHTML"
							>
								Transformer en ticket
							</button>
						}
					</div>
				</div>
				<div id="messages" class="edc-chat__messages">
					for _, m := range props.Messages {
						@component.ChatMessage(m)
					}
				</div>
				<div class="edc-chat__composer-wrap">
					<form
						class="edc-chat__composer"
						hx-post={ string(templ.SafeURL(sessionHref(props.ProjectSlug, props.CurrentSession.ID) + "/messages")) }
						hx-target="#messages"
						hx-swap="beforeend"
						hx-on::after-request="this.reset()"
					>
						<textarea
							id="composer-input"
							name="content"
							rows="1"
							class="edc-chat__composer-input"
							placeholder="Posez votre question… (Entrée pour envoyer)"
							required
							hx-on:keydown="if(event.key==='Enter' && !event.shiftKey){event.preventDefault();this.closest('form').requestSubmit();}"
						></textarea>
						<button type="submit" class="edc-chat__composer-send" aria-label="Envoyer">
							<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
								<path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path>
							</svg>
						</button>
					</form>
				</div>
			</div>
		}
	}
}

// AssistantStreamPlaceholder est ajouté à #messages juste après le message
// User : il ouvre la connexion SSE qui recevra les fragments de la réponse
// de l'agent (SPEC §Chat, point 6 ; PLAN.md §Phase 4 : SSE via hx-ext="sse").
templ AssistantStreamPlaceholder(projectSlug, sessionID string) {
	<div
		hx-ext="sse"
		sse-connect={ "/projects/" + projectSlug + "/chat/" + sessionID + "/stream" }
		sse-swap="message"
		sse-close="done"
		hx-swap="innerHTML"
	>
		@component.ChatMessage(component.ChatMessageProps{Role: "assistant", Content: "", IsStreaming: true})
	</div>
}

// RelevanceConfirmed remplace le bouton « Cet échange m'a aidé » une fois le
// signalement enregistré (SPEC §FAQ, point 29).
templ RelevanceConfirmed() {
	@component.Badge(component.BadgeProps{Variant: component.BadgeSuccess}) {
		Merci pour votre retour
	}
}

// HandoverModal ouvre la fenêtre « Transformer en ticket » : chrome de la
// modale (titre, fermeture) autour d'un corps qui déclenche lui-même, dès
// son insertion dans le DOM, la génération du brouillon — l'état "Analyse de
// la session…" de la maquette est donc affiché pendant l'appel LLM, sans
// JavaScript dédié (SPEC §Handover, point 14 ; cf. maquette Edecàn App.dc.html,
// composant HandoverModal).
templ HandoverModal(projectSlug, sessionID string) {
	<div class="edc-modal-backdrop">
		<div class="edc-modal">
			<div class="edc-modal__header">
				<div>
					<h3 class="edc-modal__title">Transformer en ticket</h3>
					<p class="edc-modal__subtitle">Brouillon généré à partir de vos échanges</p>
				</div>
				<button type="button" class="edc-modal__close" onclick="document.getElementById('modal-root').innerHTML=''" aria-label="Fermer">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M18 6L6 18M6 6l12 12"></path>
					</svg>
				</button>
			</div>
			<div
				id="handover-modal-body"
				class="edc-modal__body"
				hx-post={ string(templ.SafeURL("/projects/" + projectSlug + "/chat/" + sessionID + "/handover/draft")) }
				hx-trigger="load"
				hx-target="#handover-modal-body"
				hx-swap="innerHTML"
			>
				<div class="edc-handover-loading">
					<div class="edc-handover-loading__icon">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"></path>
						</svg>
					</div>
					<div>
						<div class="edc-handover-loading__title">Analyse de la session…</div>
						<div class="edc-handover-loading__subtitle">L'agent rédige un brouillon de ticket</div>
					</div>
					<div class="edc-handover-loading__bar"><span></span></div>
				</div>
			</div>
		</div>
	</div>
}

// HandoverDraftFragment remplace l'état de chargement de la modale par le
// brouillon généré, éditable avant soumission (SPEC §Handover, points 14-15).
// Réutilisé tel quel pour réafficher une erreur de validation après
// soumission (cf. HandoverSubmit).
templ HandoverDraftFragment(projectSlug, sessionID, title, body, errorMessage string) {
	if errorMessage != "" {
		<div style="margin-bottom:var(--space-3);">
			@component.Toast(component.ToastProps{Variant: component.ToastWarning, Message: errorMessage})
		</div>
	}
	<form
		hx-post={ string(templ.SafeURL("/projects/" + projectSlug + "/chat/" + sessionID + "/handover")) }
		hx-target="#handover-modal-body"
		hx-swap="innerHTML"
	>
		@component.Input(component.InputProps{ID: "draft-title", Name: "title", Label: "Titre", Value: title, Required: true})
		<div style="margin-top:var(--space-3);">
			@component.Textarea(component.TextareaProps{ID: "draft-body", Name: "body", Label: "Corps (Markdown)", Value: body, Rows: 12, Required: true, Mono: true})
		</div>
		<div class="edc-modal__footer" style="margin:var(--space-4) -22px -20px;">
			<button type="button" class="edc-btn edc-btn--ghost edc-btn--md" onclick="document.getElementById('modal-root').innerHTML=''">
				Annuler
			</button>
			@component.Button(component.ButtonProps{Variant: component.ButtonPrimary, Type: "submit"}) {
				Créer le ticket
			}
		</div>
	</form>
}
